      "type": "string"
    },
    "bastion_poc_test_commands": {
      "value": "\n=== Connect to bastion (no SSH key needed) ===\naws ssm start-session --target i-077c2d8c8fe17a2c5 --region us-east-1\n\n=== Step 1: create DB users once (run with master password) ===\nmysql -h aurora-readonly-db-instance-1.cuukwis7t1js.us-east-1.rds.amazonaws.com -u admin -p \u003c /tmp/create_poc_users.sql\n\n=== Step 2: test each role ===\n\n# READONLY\nCREDS=$(aws sts assume-role --role-arn arn:aws:iam::853973692277:role/aurora-okta-8a1-poc-readonly-role --role-session-name poc-readonly --query 'Credentials.[AccessKeyId,SecretAccessKey,SessionToken]' --output text)\nexport AWS_ACCESS_KEY_ID=$(echo $CREDS | awk '{print $1}')\nexport AWS_SECRET_ACCESS_KEY=$(echo $CREDS | awk '{print $2}')\nexport AWS_SESSION_TOKEN=$(echo $CREDS | awk '{print $3}')\nTOKEN=$(aws rds generate-db-auth-token --hostname aurora-readonly-db-instance-1.cuukwis7t1js.us-east-1.rds.amazonaws.com --port 3306 --region us-east-1 --username readonly_user)\nmysql -h aurora-readonly-db-instance-1.cuukwis7t1js.us-east-1.rds.amazonaws.com -u readonly_user --password=\"$TOKEN\" --ssl-mode=REQUIRED appdb\n\n# READWRITE\nunset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN\nCREDS=$(aws sts assume-role --role-arn arn:aws:iam::853973692277:role/aurora-okta-8a1-poc-readwrite-role --role-session-name poc-readwrite --query 'Credentials.[AccessKeyId,SecretAccessKey,SessionToken]' --output text)\nexport AWS_ACCESS_KEY_ID=$(echo $CREDS | awk '{print $1}')\nexport AWS_SECRET_ACCESS_KEY=$(echo $CREDS | awk '{print $2}')\nexport AWS_SESSION_TOKEN=$(echo $CREDS | awk '{print $3}')\nTOKEN=$(aws rds generate-db-auth-token --hostname aurora-readonly-db-instance-1.cuukwis7t1js.us-east-1.rds.amazonaws.com --port 3306 --region us-east-1 --username readwrite_user)\nmysql -h aurora-readonly-db-instance-1.cuukwis7t1js.us-east-1.rds.amazonaws.com -u readwrite_user --password=\"$TOKEN\" --ssl-mode=REQUIRED appdb\n\n# DBA\nunset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN\nCREDS=$(aws sts assume-role --role-arn arn:aws:iam::853973692277:role/aurora-okta-8a1-poc-dba-role --role-session-name poc-dba --query 'Credentials.[AccessKeyId,SecretAccessKey,SessionToken]' --output text)\nexport AWS_ACCESS_KEY_ID=$(echo $CREDS | awk '{print $1}')\nexport AWS_SECRET_ACCESS_KEY=$(echo $CREDS | awk '{print $2}')\nexport AWS_SESSION_TOKEN=$(echo $CREDS | awk '{print $3}')\nTOKEN=$(aws rds generate-db-auth-token --hostname aurora-readonly-db-instance-1.cuukwis7t1js.us-east-1.rds.amazonaws.com --port 3306 --region us-east-1 --username dba_user)\nmysql -h aurora-readonly-db-instance-1.cuukwis7t1js.us-east-1.rds.amazonaws.com -u dba_user --password=\"$TOKEN\" --ssl-mode=REQUIRED appdb\n\n",
      "type": "string",
      "sensitive": true
    },
    "connection_instructions": {
      "value": {
        "database": "appdb",
        "endpoint": "aurora-okta-8a1-proxy.proxy-cuukwis7t1js.us-east-1.rds.amazonaws.com",
        "instructions": "1. Login to Okta at https://trial-3604415.okta.com\n2. Navigate to the okta-aurora-app application\n3. Click to assume the aurora-readonly-role role\n4. In AWS Console, navigate to RDS Proxy\n5. Note the RDS Proxy endpoint: aurora-okta-8a1-proxy.proxy-cuukwis7t1js.us-east-1.rds.amazonaws.com\n6. Generate authentication token:\n   aws rds-db auth-token \\\n     --hostname aurora-okta-8a1-proxy.proxy-cuukwis7t1js.us-east-1.rds.amazonaws.com \\\n     --port 3306 \\\n     --region us-east-1 \\\n     --username readonly_user\n7. Connect with MySQL client:\n   mysql -h aurora-okta-8a1-proxy.proxy-cuukwis7t1js.us-east-1.rds.amazonaws.com \\\n     -P 3306 \\\n     -u readonly_user \\\n     --ssl-ca=/path/to/rds-ca-bundle.pem \\\n     --ssl-mode=VERIFY_IDENTITY \\\n     -p\"\u003cauth_token\u003e\"\n",
        "method": "RDS Proxy with IAM Authentication",
        "port": 3306,
        "region": "us-east-1",
        "user": "readonly_user"
      },
      "type": [
        "object",
        {
          "database": "string",
          "endpoint": "string",
          "instructions": "string",
          "method": "string",
          "port": "number",
          "region": "string",
          "user": "string"
        }
      ],
      "sensitive": true
    },
